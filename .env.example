# In dev, set REACHKIT_USE_FIXTURES=true to run the full funnel with NO keys (paid keys may be blank).
# For real LLM/web/email, fill the paid keys.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
TAVILY_API_KEY=
RESEND_API_KEY=
POSTHOG_KEY=
POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SCAN_BUDGET_CENTS=150
PRODUCT_HUNT_TOKEN=
YOUTUBE_API_KEY=
VOYAGE_API_KEY=
DATAFORSEO_LOCATION_CODE=2840
DATAFORSEO_LANGUAGE_CODE=en
REACHKIT_USE_FIXTURES=false

# Stripe (live billing). Leave blank in fixtures mode — checkout upgrades the
# user row directly without calling Stripe. Required only when
# REACHKIT_USE_FIXTURES=false and you want real payments.
#   STRIPE_SECRET_KEY      sk_test_… (then sk_live_… in prod)
#   STRIPE_WEBHOOK_SECRET  whsec_… from the registered webhook endpoint
#   STRIPE_PRICE_SOLO      price_… for the $29/mo recurring price
#   STRIPE_PRICE_GROWTH    price_… for the $99/mo recurring price
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_GROWTH=
