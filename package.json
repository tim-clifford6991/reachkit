{
  "name": "reachkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:inngest": "npx --yes inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "dev:all": "concurrently -k -n next,inngest -c blue,magenta \"next dev\" \"npx --yes inngest-cli@latest dev -u http://localhost:3000/api/inngest\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "check:bundle": "node scripts/check-bundle.mjs",
    "test:render": "node scripts/render-smoke.mjs",
    "eval": "vitest run --config vitest.integration.config.ts tests/eval/golden-set.eval.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@base-ui/react": "^1.5.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "geist": "^1.7.2",
    "gsap": "^3.15.0",
    "inngest": "^4.5.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "node-html-parser": "^7.1.0",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.386.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@inngest/test": "^1.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.3.0"
}
